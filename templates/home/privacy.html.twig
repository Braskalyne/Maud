{% extends 'base.html.twig' %}

{% block title %}Politique de Confidentialité - 4fam Artistes Muralistes{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        .privacy-container {
            max-width: 1000px;
            margin: 0 auto;
        }
        
        .privacy-intro {
            text-align: center;
            margin-bottom: 4rem;
        }
        
        .privacy-intro h1 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 3rem;
            font-weight: 700;
            margin-bottom: 1rem;
            letter-spacing: -0.02em;
        }
        
        .privacy-intro p {
            font-family: 'Inter', sans-serif;
            color: #888;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
            font-weight: 300;
        }
        
        .privacy-section {
            margin-bottom: 3rem;
        }
        
        .privacy-section h2 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.6rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid #f0f0f0;
            color: #0a0a0a;
        }
        
        .privacy-section h3 {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.2rem;
            font-weight: 600;
            margin: 2rem 0 1rem 0;
            color: #c9a961;
        }
        
        .privacy-section p,
        .privacy-section ul {
            font-family: 'Inter', sans-serif;
            color: #4a4a4a;
            line-height: 1.9;
            margin-bottom: 1rem;
            font-weight: 400;
        }
        
        .privacy-section ul {
            list-style: none;
            padding-left: 0;
        }
        
        .privacy-section ul li {
            padding-left: 1.5rem;
            position: relative;
            margin-bottom: 0.8rem;
        }
        
        .privacy-section ul li::before {
            content: '•';
            position: absolute;
            left: 0;
            color: #c9a961;
            font-size: 1.2rem;
        }
        
        .privacy-section strong {
            color: #0a0a0a;
            font-weight: 400;
        }
        
        .highlight-box {
            background: #f0f7ff;
            padding: 1.5rem;
            border-radius: 4px;
            border-left: 3px solid #c9a961;
            margin: 2rem 0;
        }
        
        .highlight-box p {
            margin: 0;
            font-size: 0.9rem;
        }
        
        .rights-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }
        
        .right-card {
            background: #f8f8f8;
            padding: 1.5rem;
            border-radius: 4px;
            border-top: 3px solid #c9a961;
        }
        
        .right-card h4 {
            font-size: 1rem;
            margin-bottom: 0.8rem;
            color: #0a0a0a;
        }
        
        .right-card p {
            font-size: 0.85rem;
            margin: 0;
        }
    </style>
{% endblock %}

{% block body %}
<div class="container">
    <div class="privacy-container">
        <div class="privacy-intro">
            <h1>Politique de Confidentialité</h1>
            <p>Dernière mise à jour : {{ "now"|date("d/m/Y") }}</p>
        </div>
        
        <div class="highlight-box">
            <p>
                <strong>🔒 Votre vie privée nous importe.</strong> 
                Cette politique explique comment nous collectons, utilisons et protégeons vos données personnelles 
                conformément au Règlement Général sur la Protection des Données (RGPD).
            </p>
        </div>
        
        <div class="privacy-section">
            <h2>1. Responsable du traitement des données</h2>
            <p>
                <strong>Nom :</strong> [VOTRE NOM COMPLET]<br>
                <strong>Adresse :</strong> [VOTRE ADRESSE]<br>
                <strong>Email :</strong> <a href="mailto:contact@maud-muraliste.fr" style="color: #c9a961;">contact@maud-muraliste.fr</a>
            </p>
        </div>
        
        <div class="privacy-section">
            <h2>2. Données collectées</h2>
            
            <h3>Via le formulaire de contact</h3>
            <p>Lorsque vous nous contactez via le formulaire, nous collectons :</p>
            <ul>
                <li><strong>Nom :</strong> Pour vous identifier et personnaliser notre réponse</li>
                <li><strong>Adresse email :</strong> Pour pouvoir vous répondre</li>
                <li><strong>Sujet du message :</strong> Pour comprendre votre demande</li>
                <li><strong>Contenu du message :</strong> Pour traiter votre demande</li>
            </ul>
            
            <h3>Données techniques</h3>
            <p>Nous collectons automatiquement certaines données techniques :</p>
            <ul>
                <li>Cookies de session (nécessaires au fonctionnement du site)</li>
                <li>Adresse IP (pour la sécurité et la détection d'abus)</li>
                <li>Données de navigation (pour les logs serveur uniquement)</li>
            </ul>
            
            <p><strong>⚠️ Nous ne collectons AUCUNE donnée avec Google Analytics, Facebook Pixel ou autre outil de tracking publicitaire.</strong></p>
        </div>
        
        <div class="privacy-section">
            <h2>3. Finalités du traitement</h2>
            <p>Vos données sont utilisées uniquement pour :</p>
            <ul>
                <li><strong>Répondre à vos demandes</strong> de contact ou de devis</li>
                <li><strong>Assurer la sécurité</strong> du site et prévenir les abus</li>
                <li><strong>Respecter nos obligations légales</strong></li>
            </ul>
            
            <p><strong>Nous ne vendons ni ne louons vos données à des tiers.</strong></p>
        </div>
        
        <div class="privacy-section">
            <h2>4. Base légale du traitement</h2>
            <p>Le traitement de vos données repose sur :</p>
            <ul>
                <li><strong>Votre consentement</strong> (case cochée dans le formulaire de contact)</li>
                <li><strong>L'intérêt légitime</strong> pour assurer la sécurité du site</li>
                <li><strong>Les obligations légales</strong> (mentions légales, comptabilité)</li>
            </ul>
        </div>
        
        <div class="privacy-section">
            <h2>5. Durée de conservation</h2>
            <ul>
                <li><strong>Messages de contact :</strong> Conservés 3 ans maximum après le dernier échange</li>
                <li><strong>Logs serveur :</strong> Conservés 12 mois maximum</li>
                <li><strong>Cookies de session :</strong> Supprimés à la fermeture du navigateur</li>
            </ul>
        </div>
        
        <div class="privacy-section">
            <h2>6. Destinataires des données</h2>
            <p>Vos données sont accessibles uniquement à :</p>
            <ul>
                <li><strong>[VOTRE NOM]</strong> (propriétaire du site)</li>
                <li><strong>Hébergeur du site :</strong> [NOM HÉBERGEUR] (pour l'hébergement technique)</li>
                <li><strong>Service d'emailing :</strong> Gmail (Google) pour l'envoi/réception des emails</li>
            </ul>
            <p>Aucune autre personne ou entreprise n'a accès à vos données.</p>
        </div>
        
        <div class="privacy-section">
            <h2>7. Vos droits</h2>
            <p>Conformément au RGPD, vous disposez des droits suivants :</p>
            
            <div class="rights-grid">
                <div class="right-card">
                    <h4>🔍 Droit d'accès</h4>
                    <p>Vous pouvez demander une copie de toutes les données que nous détenons sur vous.</p>
                </div>
                
                <div class="right-card">
                    <h4>✏️ Droit de rectification</h4>
                    <p>Vous pouvez demander la correction de données inexactes ou incomplètes.</p>
                </div>
                
                <div class="right-card">
                    <h4>🗑️ Droit à l'effacement</h4>
                    <p>Vous pouvez demander la suppression de vos données personnelles.</p>
                </div>
                
                <div class="right-card">
                    <h4>⛔ Droit d'opposition</h4>
                    <p>Vous pouvez vous opposer au traitement de vos données pour motifs légitimes.</p>
                </div>
                
                <div class="right-card">
                    <h4>📦 Droit à la portabilité</h4>
                    <p>Vous pouvez récupérer vos données dans un format structuré et lisible.</p>
                </div>
                
                <div class="right-card">
                    <h4>🚫 Droit de limitation</h4>
                    <p>Vous pouvez demander la limitation du traitement de vos données.</p>
                </div>
            </div>
            
            <p>
                <strong>Pour exercer vos droits,</strong> contactez-nous à l'adresse : 
                <a href="mailto:contact@maud-muraliste.fr" style="color: #c9a961;">contact@maud-muraliste.fr</a>
            </p>
            <p>
                Nous répondrons à votre demande dans un délai maximum d'<strong>1 mois</strong>.
            </p>
        </div>
        
        <div class="privacy-section">
            <h2>8. Sécurité des données</h2>
            <p>Nous mettons en œuvre les mesures de sécurité suivantes :</p>
            <ul>
                <li>Connexion HTTPS sécurisée (certificat SSL)</li>
                <li>Stockage sécurisé des emails</li>
                <li>Accès restreint aux données personnelles</li>
                <li>Mises à jour régulières du système</li>
            </ul>
        </div>
        
        <div class="privacy-section">
            <h2>9. Transfert de données hors UE</h2>
            <p>
                Les emails sont hébergés par Google (Gmail). Google respecte le RGPD et a mis en place des 
                clauses contractuelles types approuvées par la Commission européenne pour encadrer les transferts 
                de données vers les États-Unis.
            </p>
        </div>
        
        <div class="privacy-section">
            <h2>10. Cookies</h2>
            <p>
                Ce site utilise uniquement des <strong>cookies techniques essentiels</strong> au fonctionnement 
                (cookies de session Symfony). Ces cookies sont exemptés de consentement selon la CNIL.
            </p>
            <p>
                Nous n'utilisons <strong>aucun cookie publicitaire, analytique ou de réseaux sociaux</strong>.
            </p>
        </div>
        
        <div class="privacy-section">
            <h2>11. Réclamation</h2>
            <p>
                Si vous estimez que vos droits ne sont pas respectés, vous pouvez introduire une réclamation auprès de la 
                <strong>Commission Nationale de l'Informatique et des Libertés (CNIL)</strong> :
            </p>
            <p>
                CNIL - 3 Place de Fontenoy - TSA 80715 - 75334 PARIS CEDEX 07<br>
                Site web : <a href="https://www.cnil.fr" target="_blank" style="color: #c9a961;">www.cnil.fr</a>
            </p>
        </div>
        
        <div class="privacy-section">
            <h2>12. Modifications de cette politique</h2>
            <p>
                Nous nous réservons le droit de modifier cette politique de confidentialité à tout moment. 
                La date de dernière mise à jour est indiquée en haut de cette page.
            </p>
            <p>
                Nous vous encourageons à consulter régulièrement cette page pour rester informé de la manière 
                dont nous protégeons vos données.
            </p>
        </div>
        
        <div class="highlight-box">
            <p>
                <strong>Des questions ?</strong> 
                N'hésitez pas à nous contacter à 
                <a href="mailto:contact@maud-muraliste.fr" style="color: #c9a961;">contact@maud-muraliste.fr</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
