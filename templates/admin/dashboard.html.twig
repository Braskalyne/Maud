{% extends 'admin/base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block body %}
<div class="content-box">
    <h1>Bienvenue dans l'administration</h1>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-top: 2rem;">
        <div style="background: #3498db; color: white; padding: 2rem; border-radius: 10px; text-align: center;">
            <h2 style="color: white; margin-bottom: 0.5rem;">📸 Galeries</h2>
            <p style="font-size: 1.2rem;">Gérer les réalisations</p>
            <a href="{{ path('admin_gallery_index') }}" style="color: white; text-decoration: underline; display: block; margin-top: 1rem;">Accéder →</a>
        </div>
        
        <div style="background: #e74c3c; color: white; padding: 2rem; border-radius: 10px; text-align: center;">
            <h2 style="color: white; margin-bottom: 0.5rem;">🎬 Médias</h2>
            <p style="font-size: 1.2rem;">Gérer photos & vidéos</p>
            <a href="{{ path('admin_media_index') }}" style="color: white; text-decoration: underline; display: block; margin-top: 1rem;">Accéder →</a>
        </div>
        
        <div style="background: #27ae60; color: white; padding: 2rem; border-radius: 10px; text-align: center;">
            <h2 style="color: white; margin-bottom: 0.5rem;">🌐 Site web</h2>
            <p style="font-size: 1.2rem;">Voir le site public</p>
            <a href="{{ path('app_home') }}" style="color: white; text-decoration: underline; display: block; margin-top: 1rem;">Visiter →</a>
        </div>
    </div>
</div>
{% endblock %}
