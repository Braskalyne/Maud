{% extends 'admin/base.html.twig' %}

{% block title %}Médias{% endblock %}
{% block page_title %}Gestion des médias{% endblock %}

{% block body %}
<div class="content-box">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1>Médias</h1>
        <a href="{{ path('admin_media_new') }}" class="btn btn-success">+ Nouveau média</a>
    </div>
    
    {% if medias is empty %}
        <p style="text-align: center; color: #999; padding: 3rem;">Aucun média pour le moment.</p>
    {% else %}
        <table>
            <thead>
                <tr>
                    <th>Aperçu</th>
                    <th>Type</th>
                    <th>Titre</th>
                    <th>Position</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for media in medias %}
                    <tr>
                        <td>
                            {% if media.type == 'image' %}
                                <img src="/uploads/gallery/{{ media.filename }}" style="width: 80px; height: 60px; object-fit: cover; border-radius: 5px;" alt="{{ media.title }}">
                            {% else %}
                                <span style="font-size: 2rem;">🎬</span>
                            {% endif %}
                        </td>
                        <td>{{ media.type == 'image' ? 'Image' : 'Vidéo' }}</td>
                        <td><strong>{{ media.title ?? 'Sans titre' }}</strong></td>
                        <td>{{ media.position }}</td>
                        <td>
                            {% if media.isPublished %}
                                <span style="color: #27ae60;">✓ Publié</span>
                            {% else %}
                                <span style="color: #e74c3c;">✗ Brouillon</span>
                            {% endif %}
                        </td>
                        <td>
                            <a href="{{ path('admin_media_edit', {id: media.id}) }}" class="btn" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Modifier</a>
                            <form method="post" action="{{ path('admin_media_delete', {id: media.id}) }}" style="display: inline;" onsubmit="return confirm('Supprimer ce média ?');">
                                <button type="submit" class="btn btn-danger" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}
</div>
{% endblock %}
