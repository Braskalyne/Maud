{% extends 'admin/base.html.twig' %}

{% block title %}Nouveau média{% endblock %}
{% block page_title %}Nouveau média{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .media-type-selector {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 2rem;
        }
        
        .media-type-option {
            position: relative;
            padding: 2rem;
            border: 2px solid #ddd;
            border-radius: 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .media-type-option input[type="radio"] {
            position: absolute;
            left: 10px;
            top: 10px;
            width: 20px;
            height: 20px;
            opacity: 1;
            cursor: pointer;
        }
        
        .media-type-option:hover {
            border-color: #3498db;
        }
        
        .media-type-option.selected {
            border-color: #3498db;
            background: #e8f4fd;
        }
        
        .media-fields {
            display: none;
        }
        
        .media-fields.active {
            display: block;
        }
    </style>
{% endblock %}

{% block body %}
<div class="content-box">
    <h1>Ajouter un nouveau média</h1>
    
    <form method="post" enctype="multipart/form-data" id="mediaForm" data-turbo="false">
        <div class="media-type-selector">
            <div class="media-type-option" onclick="selectMediaTypeClick('image')">
                <input type="radio" name="type" value="image" id="type_image" required>
                <label for="type_image" style="cursor: pointer; display: block; margin: 0;">
                    <h3>📷 Image</h3>
                    <p>Télécharger une photo</p>
                </label>
            </div>
            <div class="media-type-option" onclick="selectMediaTypeClick('video')">
                <input type="radio" name="type" value="video" id="type_video" required>
                <label for="type_video" style="cursor: pointer; display: block; margin: 0;">
                    <h3>🎬 Vidéo</h3>
                    <p>Lien YouTube</p>
                </label>
            </div>
        </div>
        
        <div id="image-fields" class="media-fields">
            <div class="form-group">
                <label for="image">Image *</label>
                <input type="file" id="image" name="image" accept="image/*">
            </div>
        </div>
        
        <div id="video-fields" class="media-fields">
            <div class="form-group">
                <label for="youtube_url">URL YouTube *</label>
                <input type="url" id="youtube_url" name="youtube_url" placeholder="https://www.youtube.com/watch?v=...">
            </div>
        </div>
        
        <div class="form-group">
            <label for="title">Titre</label>
            <input type="text" id="title" name="title">
        </div>
        
        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description"></textarea>
        </div>
        
        <div class="form-group">
            <label for="position">Position</label>
            <input type="number" id="position" name="position" value="0">
        </div>
        
        <div class="form-group">
            <label>
                <input type="checkbox" name="published" value="1" checked> Publier
            </label>
        </div>
        
        <div class="form-actions">
            <button type="submit" class="btn btn-success">Ajouter le média</button>
            <a href="{{ path('admin_media_index') }}" class="btn">Annuler</a>
        </div>
    </form>
</div>

<script>
    function selectMediaTypeClick(type) {
        // Explicitly check the radio button
        const radio = document.getElementById('type_' + type);
        if (radio) {
            radio.checked = true;
        }
        
        // Update visual selection
        document.querySelectorAll('.media-type-option').forEach(el => {
            el.classList.remove('selected');
        });
        
        const selectedInput = document.querySelector(`input[name="type"][value="${type}"]`);
        if (selectedInput) {
            selectedInput.closest('.media-type-option').classList.add('selected');
        }
        
        // Show/hide appropriate fields
        document.querySelectorAll('.media-fields').forEach(el => {
            el.classList.remove('active');
        });
        document.getElementById(type + '-fields').classList.add('active');
        
        // Update required fields
        if (type === 'image') {
            const imageInput = document.getElementById('image');
            const youtubeInput = document.getElementById('youtube_url');
            if (imageInput) imageInput.required = true;
            if (youtubeInput) youtubeInput.required = false;
        } else {
            const imageInput = document.getElementById('image');
            const youtubeInput = document.getElementById('youtube_url');
            if (imageInput) imageInput.required = false;
            if (youtubeInput) youtubeInput.required = true;
        }
    }
    
    // Debug: log form data before submit
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('mediaForm');
        if (form) {
            form.addEventListener('submit', function(e) {
                const formData = new FormData(form);
                console.log('Form data:', Object.fromEntries(formData));
                console.log('Type value:', formData.get('type'));
            });
        }
    });
</script>
{% endblock %}
